generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum LeadStatus {
  NEW
  CONTACTED
  PRE_QUALIFIED
  APPLIED
  APPROVED
  FUNDED
  LOST
}

enum PropertyType {
  PURCHASE
  REFINANCE
  RENEWAL
  HELOC
  CONSTRUCTION
}

enum CreditRange {
  EXCELLENT
  GOOD
  FAIR
  POOR
  UNKNOWN
}

enum RateType {
  FIXED
  VARIABLE
  ADJUSTABLE
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String
  lastName  String
  email     String
  phone     String

  propertyType  PropertyType
  purchasePrice Float?
  downPayment   Float?
  creditRange   CreditRange  @default(UNKNOWN)
  employment    String?

  rateType      RateType?
  term          Int?
  quotedRate    Float?

  referredBy   String?
  referralType String?

  source  String     @default("web-form")
  message String?    @db.Text
  status  LeadStatus @default(NEW)

  contact Contact?
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  dateOfBirth  DateTime?
  employer     String?
  annualIncome Float?
  monthlyDebts Float?
  address      String?

  notes     Note[]
  followUps FollowUp[]
  documents Document[]
}

model Note {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  content String  @db.Text
  type    String  @default("general")
}

model FollowUp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  dueDate     DateTime
  title       String
  description String?  @db.Text
  completed   Boolean  @default(false)
  completedAt DateTime?
}

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  name String
  url  String
  type String
}
